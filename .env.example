# OpenAI
OPENAI_API_KEY=your-openai-api-key
NEWS_AGENT_MODEL=gpt-5.4

# Daily schedule
NEWS_TIMEZONE=Asia/Shanghai
NEWS_RUN_TIME=09:00
NEWS_MAX_ARTICLES=80
NEWS_STORY_LIMIT=12
NEWS_TOPICS=全球头条, 科技与AI, 地缘政治, 宏观经济与市场, 加密货币政策, 中国与全球贸易科技关系, 体育重大事件, 商业与大公司
NEWS_EMAIL_REQUIREMENTS=用中文写，重点说明为什么重要；每条新闻保留来源和链接；忙碌读者可以在5分钟内读完。

# Email
NEWS_EMAIL_TO=receiver@example.com, second@example.com
NEWS_EMAIL_FROM=your-email@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=
SMTP_USE_SSL=false




